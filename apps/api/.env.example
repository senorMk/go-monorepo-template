APP_ENV=development
PORT=3000

DATABASE_URL=postgresql://APP_SNAKE:password@localhost:5432/APP_SNAKE_dev

JWT_SECRET=change-me-to-a-256-bit-random-string
JWT_REFRESH_SECRET=change-me-to-another-256-bit-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=720h

CORS_ORIGINS=http://localhost:4000

EMAIL_FROM=info@APP_DOMAIN

# Deep-link scheme used in confirmation / reset emails (e.g. my-app://...)
APP_SCHEME=APP_NAME
